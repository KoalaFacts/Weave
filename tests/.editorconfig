# EditorConfig overrides for test projects

[*.cs]

# Test methods use descriptive names without Async suffix
dotnet_naming_rule.async_methods_should_end_with_async.severity = none

# CA1707: Identifiers should not contain underscores (test method naming uses underscores)
dotnet_diagnostic.CA1707.severity = none

# CA1861: Prefer 'static readonly' fields over constant array arguments (noisy in test setup)
dotnet_diagnostic.CA1861.severity = none

# CA2007: Do not directly await a Task (already disabled globally, reinforced here)
dotnet_diagnostic.CA2007.severity = none

# CA1062: Validate arguments of public methods (test methods don't need parameter validation)
dotnet_diagnostic.CA1062.severity = none

# CA1034: Nested types should not be visible (test helper types)
dotnet_diagnostic.CA1034.severity = none

# CA1812: Avoid uninstantiated internal classes (test fixtures instantiated by xunit)
dotnet_diagnostic.CA1812.severity = none

# CA1859: Use concrete types when possible for improved performance (relaxed in tests)
dotnet_diagnostic.CA1859.severity = none

# CA2234: Pass System.Uri objects instead of strings (relaxed in tests)
dotnet_diagnostic.CA2234.severity = none

# IDE0060: Remove unused parameter (xunit theory parameters, fixture constructors)
dotnet_diagnostic.IDE0060.severity = none

# xUnit1051: Use TestContext.Current.CancellationToken (noisy for tests with many async calls)
dotnet_diagnostic.xUnit1051.severity = suggestion
