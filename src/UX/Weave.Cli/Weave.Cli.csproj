<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>weave</ToolCommandName>
    <AssemblyName>weave</AssemblyName>
    <PackageId>Weave.Cli</PackageId>
    <Description>CLI for Weave — set up AI assistants with guardrails you control.</Description>
  </PropertyGroup>

  <!-- AOT size optimization — applied only during publish -->
  <PropertyGroup Condition="'$(PublishAot)' == 'true'">
    <InvariantGlobalization>true</InvariantGlobalization>
    <OptimizationPreference>Size</OptimizationPreference>
    <StripSymbols>true</StripSymbols>
    <DebugType>none</DebugType>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Foundation\Weave.Shared\Weave.Shared.csproj" />
    <ProjectReference Include="..\..\Workspaces\Weave.Workspaces\Weave.Workspaces.csproj" />
    <ProjectReference Include="..\..\Deployment\Weave.Deploy\Weave.Deploy.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Spectre.Console" />
    <PackageReference Include="System.CommandLine" />
  </ItemGroup>

</Project>
