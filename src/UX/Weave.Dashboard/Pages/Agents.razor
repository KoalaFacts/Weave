@page "/agents"

<PageTitle>Agents - Weave</PageTitle>

<FluentLabel Typo="Typography.H4" Style="margin-bottom: 1rem;">Agent Console</FluentLabel>

@if (_error is not null)
{
    <FluentMessageBar Intent="MessageIntent.Error" Style="margin-bottom: 1rem;">@_error</FluentMessageBar>
}

<FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16" Style="height: 500px;">
    <FluentCard Style="width: 250px; padding: 1rem;">
        <FluentLabel Typo="Typography.Subject" Style="margin-bottom: 0.5rem;">Active Agents</FluentLabel>
        @if (_loading)
        {
            <FluentProgressRing />
        }
        else if (_agents.Count == 0)
        {
            <FluentLabel Typo="Typography.Body">No agents active</FluentLabel>
        }
        @foreach (var agent in _agents)
        {
            <FluentButton Appearance="@(_selectedAgent?.AgentName == agent.AgentName ? Appearance.Accent : Appearance.Stealth)"
                          Style="width: 100%; margin-bottom: 4px;"
                          OnClick="@(() => SelectAgent(agent))">
                @agent.AgentName (@agent.Status)
            </FluentButton>
        }
    </FluentCard>

    <FluentCard Style="flex: 1; padding: 1rem; display: flex; flex-direction: column;">
        <FluentLabel Typo="Typography.Subject" Style="margin-bottom: 0.5rem;">
            @(_selectedAgent?.AgentName ?? "Select an agent")
        </FluentLabel>

        @if (_selectedAgent is not null)
        {
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Style="margin-bottom: 0.5rem;">
                <FluentBadge>@_selectedAgent.Status</FluentBadge>
                @if (_selectedAgent.Model is not null)
                {
                    <FluentBadge Appearance="Appearance.Neutral">@_selectedAgent.Model</FluentBadge>
                }
                @foreach (var tool in _selectedAgent.ConnectedTools)
                {
                    <FluentBadge Appearance="Appearance.Neutral">@tool</FluentBadge>
                }
            </FluentStack>
        }

        <div style="flex: 1; overflow-y: auto; margin-bottom: 0.5rem;">
            @foreach (var msg in _messages)
            {
                <div style="margin-bottom: 0.5rem;">
                    <FluentLabel Typo="Typography.Body"><strong>@msg.Role:</strong> @msg.Content</FluentLabel>
                </div>
            }
        </div>

        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
            <FluentTextField @bind-Value="_inputMessage" Placeholder="Send message..."
                             Style="flex: 1;" Disabled="@(_selectedAgent is null || _sending)" />
            <FluentButton Appearance="Appearance.Accent" OnClick="SendMessage"
                          Disabled="@(_selectedAgent is null || _sending)">
                @(_sending ? "Sending..." : "Send")
            </FluentButton>
        </FluentStack>
    </FluentCard>
</FluentStack>
