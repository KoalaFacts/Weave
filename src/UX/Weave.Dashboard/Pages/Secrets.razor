@page "/secrets"

<PageTitle>Secrets - Weave</PageTitle>

<FluentLabel Typo="Typography.H4" Style="margin-bottom: 1rem;">Secrets Management</FluentLabel>

<FluentCard Style="padding: 1rem; margin-bottom: 1.5rem; max-width: 600px; background: var(--neutral-layer-2);">
    <FluentLabel Typo="Typography.Body">
        Secret management is handled through the workspace manifest and the configured secrets provider.
        Vault, environment variable, and encrypted file providers are supported.
    </FluentLabel>
</FluentCard>

<FluentLabel Typo="Typography.Subject" Style="margin-bottom: 0.5rem;">Configured Provider</FluentLabel>
<FluentCard Style="padding: 1rem; max-width: 500px; margin-bottom: 1.5rem;">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentLabel Typo="Typography.Body">
            The active secrets provider is determined per workspace by the <code>secrets.provider</code> field in
            <code>workspace.json</code>.
        </FluentLabel>
        <FluentLabel Typo="Typography.Body">
            Supported values: <strong>env</strong>, <strong>file</strong>, <strong>vault</strong>
        </FluentLabel>
    </FluentStack>
</FluentCard>

<FluentLabel Typo="Typography.Subject" Style="margin-bottom: 0.5rem;">Security Controls</FluentLabel>
<FluentCard Style="padding: 1rem; max-width: 500px;">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentLabel Typo="Typography.Body">&#x2022; Capability tokens gate tool access</FluentLabel>
        <FluentLabel Typo="Typography.Body">&#x2022; Tool input and output are scanned for leaked secrets</FluentLabel>
        <FluentLabel Typo="Typography.Body">&#x2022; Secret substitution is performed through the proxy grain</FluentLabel>
        <FluentLabel Typo="Typography.Body">&#x2022; Invocations are blocked when leak scanning detects exposure</FluentLabel>
    </FluentStack>
</FluentCard>
