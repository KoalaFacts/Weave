@page "/tools"

<PageTitle>Tools - Weave</PageTitle>

<FluentLabel Typo="Typography.H4" Style="margin-bottom: 1rem;">Tool Connections</FluentLabel>

@if (_loading)
{
    <FluentProgressRing />
}
else if (_error is not null)
{
    <FluentMessageBar Intent="MessageIntent.Error">@_error</FluentMessageBar>
}
else if (_tools.Count == 0)
{
    <FluentLabel Typo="Typography.Body">No tools connected. Start a workspace to register tools.</FluentLabel>
}
else
{
    <FluentDataGrid Items="@_tools.AsQueryable()" GridTemplateColumns="1fr 120px 120px 1fr 160px">
        <PropertyColumn Property="@(t => t.ToolName)" Title="Tool" />
        <PropertyColumn Property="@(t => t.ToolType)" Title="Type" />
        <TemplateColumn Title="Status">
            <FluentBadge Appearance="@GetStatusAppearance(context.Status)">@context.Status</FluentBadge>
        </TemplateColumn>
        <PropertyColumn Property="@(t => t.Endpoint)" Title="Endpoint" />
        <PropertyColumn Property="@(t => t.ConnectedAt)" Title="Connected" Format="g" />
    </FluentDataGrid>
}
